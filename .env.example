# Environment Configuration for Softmaxxer

# Node Environment
# Set to "production" for deployment, "development" for local development
NODE_ENV=production

# Email Service (Optional)
# If using Resend for email capture/notifications
# RESEND_API_KEY=re_your_api_key_here

# Analytics (Optional - if adding PostHog or similar)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Base URL (Required for production)
# Used for generating share links and canonical URLs
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# Feature Flags (Optional)
# NEXT_PUBLIC_ENABLE_AFFILIATE_LINKS=false
# NEXT_PUBLIC_ENABLE_EMAIL_CAPTURE=false
